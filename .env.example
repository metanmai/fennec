# fennec — environment variable template
#
# Copy this file to `.env` (NOT committed; see `.gitignore`). Phase 1 reads
# these for the daemon, backend, and signing pipelines. Every variable is a
# placeholder — production values come from Cloudflare/Supabase dashboards,
# Apple Developer portal, Windows EV cert vendor, and OAuth provider
# consoles.
#
# Plan 01-01 ships this template; later plans (01-04 daemon, 01-05 backend,
# 01-08 signing) read concrete values out of `.env`.

# ─────────────────────────────────────────────────────────────────────────
# Daemon ↔ Backend transport
# ─────────────────────────────────────────────────────────────────────────

# Backend base URL the daemon's sync loop POSTs to. Production:
# https://api.fennec.dev — dev / self-host: http://localhost:8787
FENNEC_API_URL=https://api.fennec.dev

# Loopback port the daemon's HTTP bridge listens on (for the hook shim).
# Bound to 127.0.0.1 only; see daemon/src/adapters/loopback-bridge.
FENNEC_DAEMON_PORT=7821

# Shared secret between the compiled hook shim and the daemon. Generated
# per-install by the postinstall script; rotated only on uninstall+reinstall.
# Must be 32-byte base64 in production.
FENNEC_SHIM_SECRET=<32-byte-random-base64>

# ─────────────────────────────────────────────────────────────────────────
# Backend → database (Supabase Postgres via Cloudflare Hyperdrive)
# ─────────────────────────────────────────────────────────────────────────

# Postgres connection string used by the Worker via Hyperdrive binding.
# Supabase pooled connection URL (port 6543) is the default; direct (5432)
# only for migrations.
FENNEC_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase project URL (e.g., https://<ref>.supabase.co)
SUPABASE_URL=https://<project>.supabase.co

# Service-role JWT — backend ONLY (never ship to frontend or daemon).
# Used by the ingest endpoint for admin-context writes that bypass RLS
# for the demonstrably-safe upsert paths.
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

# Personal access token used by `supabase db push` from CI / local dev.
# NOT used at runtime.
SUPABASE_ACCESS_TOKEN=<personal-access-token>

# ─────────────────────────────────────────────────────────────────────────
# Cloudflare deploys
# ─────────────────────────────────────────────────────────────────────────

CLOUDFLARE_ACCOUNT_ID=<account-id>
CLOUDFLARE_API_TOKEN=<api-token>

# ─────────────────────────────────────────────────────────────────────────
# Code-signing pipeline (Phase 1 critical path per D-05)
# ─────────────────────────────────────────────────────────────────────────

# Apple Developer Program team ID (10-char alphanumeric). Required for
# productsign + notarytool. $99/yr program membership.
APPLE_DEVELOPER_TEAM_ID=<team-id>

# notarytool keychain profile name (`xcrun notarytool store-credentials ...`).
# This is a label, not a credential — credentials live in macOS keychain.
APPLE_NOTARY_KEYCHAIN_PROFILE=fennec-notary

# Windows EV cert vendor — procurement tracker only. Not consumed at runtime.
# Values: DigiCert | Sectigo | Certera | <other>
WINDOWS_EV_CERT_VENDOR=<DigiCert|Sectigo|Certera>

# ─────────────────────────────────────────────────────────────────────────
# Dev-OAuth (AUTH-16) — daemon dev identity attach via SSO
# ─────────────────────────────────────────────────────────────────────────

OAUTH_GOOGLE_CLIENT_ID=<google-oauth-client>
OAUTH_GITHUB_CLIENT_ID=<github-oauth-client>
OAUTH_MICROSOFT_CLIENT_ID=<microsoft-oauth-client>
